{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DIID",
  "version": "1.0.1",
  "identifier": "in.dorozhk.diid",
  "build": {
    "frontendDist": "../../frontend/dist-desktop"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "DIID",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "url": "http://localhost:38291"
      }
    ],
    "security": {
      "csp": "default-src 'self' http://localhost:38291; connect-src http://localhost:38291; img-src 'self' http://localhost:38291 data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../dist/diid-backend/": "diid-backend/"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
